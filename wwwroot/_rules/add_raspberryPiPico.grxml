<?xml version="1.0"?>
<grammarRule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <name>add_raspberryPiPico</name>
  <L>
    <nodes>
      <node xsi:type="ruleNode">
        <localLabels>
          <string>user_component</string>
          <string>raspberryPiPico</string>
        </localLabels>
      </node>
    </nodes>
    <arcs />
  </L>
  <K>
    <nodes>
      <node xsi:type="ruleNode">
        <localLabels>
          <string>user_component</string>
          <string>raspberryPiPico</string>
        </localLabels>
      </node>
    </nodes>
    <arcs />
  </K>
  <R>
    <nodes>
      <node xsi:type="ruleNode">
        <localLabels>
          <string>user_component</string>
          <string>raspberryPiPico</string>
        </localLabels>
        <newLabel>raspberryPiPico</newLabel>
        <newName>raspberryPiPico</newName>
      </node>

      <node xsi:type="ruleNode">
        <localLabels><string>raspberryPiPico</string><string>power</string><string>VBUS</string></localLabels>
        <newLabel>power</newLabel>
        <newName>VBUS</newName>
      </node>
      <node xsi:type="ruleNode">
        <localLabels><string>raspberryPiPico</string><string>power</string><string>VSYS</string></localLabels>
        <newLabel>power</newLabel>
        <newName>VSYS</newName>
      </node>
      <node xsi:type="ruleNode">
        <localLabels><string>raspberryPiPico</string><string>power</string><string>3V3</string></localLabels>
        <newLabel>power</newLabel>
        <newName>3V3</newName>
      </node>
      <node xsi:type="ruleNode">
        <localLabels><string>raspberryPiPico</string><string>ground</string><string>gnd</string></localLabels>
        <newLabel>ground</newLabel>
        <newName>gnd</newName>
      </node>

      <node xsi:type="ruleNode"><localLabels><string>raspberryPiPico</string><string>gpio</string><string>gp0</string></localLabels><newLabel>gpio</newLabel><newName>gp0</newName></node>
      <node xsi:type="ruleNode"><localLabels><string>raspberryPiPico</string><string>gpio</string><string>gp1</string></localLabels><newLabel>gpio</newLabel><newName>gp1</newName></node>

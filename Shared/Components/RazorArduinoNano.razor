    private void down()
    {
        if (this.resetPressed)
        {
            return;
        }
        this.resetPressed = true;
        this.resetStroke = "#333";
    }

    private void up()
    {
        if (!this.resetPressed)
        {
            return;
        }
        this.resetPressed = false;
        this.resetStroke = "";
    }

    private void leave()
    {
        this.up();
    }

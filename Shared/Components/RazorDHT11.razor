@code {
    // DHT11

    public static ElementPin[] pinInfo
    {
        get
        {
            return new ElementPin[]
            {
                new ElementPin(name: "VCC",  x: 40,   y: 139, signals: new PinSignalInfo[]{ }, number: 1),
                new ElementPin(name: "DATA", x: 49.8, y: 139, signals: new PinSignalInfo[]{ }, number: 2),
                new ElementPin(name: "NC",   x: 59.6, y: 139, signals: new PinSignalInfo[]{ }, number: 3),
                new ElementPin(name: "GND",  x: 69.4, y: 139, signals: new PinSignalInfo[]{ }, number: 4),
            };
        }
    }

    // Have the same name as in the actual component (parameters shown in UI)
    [Parameter] [ValueSetting("%", 40, 0, 100)]
    public double humidity { get; set; }

    [Parameter] [ValueSetting("°C", 20, -40, 80)]
    public double temperature { get; set; }

    // DHT11 protocol usually reports integer humidity/temp (decimals are typically 0)
    protected string getSignal()
    {
        int humInt = (int)Math.Round(humidity);
        int humDec = 0;

        int tempInt = (int)Math.Round(temperature);
        int tempDec = 0;

        int checksum = (humInt + humDec + tempInt + tempDec) & 0xFF;

        return $"{humInt:D3} {humDec:D3} {tempInt:D3} {tempDec:D3} {checksum:D3}";
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        // ensure controller receives updated settings
        // NOTE: Controller messaging is handled by RazorComponent.OnAfterRenderAsync in other components,
        // but this component follows the same "parameters only" pattern as RazorDHT22.
    }

    // If your UI expects this exact method name (like RazorDHT22 does), keep it:
    public string translateSystemToComponent(string pinName)
    {
        // map system pin names to component pin names
        // (keep simple; this matches how other components behave)
        return pinName;
    }
}


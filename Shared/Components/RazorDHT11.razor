@using Microsoft.AspNetCore.Components

@* DHT11 sensor component *@
<div class="sensor">
    <h4>DHT11 Sensor</h4>
    <p><strong>Temperature:</strong> @temperature °C</p>
    <p><strong>Humidity:</strong> @humidity %</p>

    <div class="pins">
        @foreach (var pin in pinInfo)
        {
            <div class="pin">@pin</div>
        }
    </div>

    <svg width="100" height="100" viewBox="0 0 100 100">
        <rect x="10" y="10" width="80" height="80" fill="lightblue" stroke="black" />
        <text x="50" y="55" text-anchor="middle" font-size="12" fill="black">DHT11</text>
    </svg>
</div>

@code {
    // These names MUST match the incoming parameter names used elsewhere in the app (lowercase).
    [Parameter] public double temperature { get; set; }
    [Parameter] public double humidity { get; set; }

    // Many rules ignore the NC pin and only model VCC/DATA/GND.
    private readonly string[] pinInfo = new[] { "VCC", "DATA", "GND" };
}
